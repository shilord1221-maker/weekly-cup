# Сервер
NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:3000

# База данных
DATABASE_URL=postgresql://weeklycup:weeklycup@localhost:5432/weeklycup?schema=public

# Redis (сессии, таймеры, pub/sub для Socket.io)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Discord (для будущей интеграции через API; пока используются ручные invite-ссылки)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# S3 / R2 для медиа (опционально)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
