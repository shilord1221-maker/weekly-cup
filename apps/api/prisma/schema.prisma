// Weekly Cup — Prisma schema
// PostgreSQL. UTC хранится в БД, конвертация в МСК — на фронте.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── ENUMS ─────────────────────────

enum Role {
  OWNER
  ADMIN
  ORGANIZER
  PLAYER
}

enum MatchMode {
  MODE_2X2
  MODE_3X3
  MODE_4X4
  MODE_5X5
}

enum MatchStatus {
  DRAFT
  SCHEDULED
  LIVE
  PAUSED
  FINISHED
  CANCELLED
}

enum LobbyState {
  DRAFT
  OPEN
  READY
  IN_PROGRESS
  FINISHED
  CANCELLED
}

enum ComplaintStatus {
  NEW
  IN_REVIEW
  RESOLVED
  REJECTED
}

enum AmnestyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AvatarStatus {
  PENDING
  APPROVED
  REJECTED
}

// ───────────────────────── CORE ─────────────────────────

model User {
  id           String   @id @default(uuid())
  username     String   @unique @db.VarChar(32)
  email        String   @unique @db.VarChar(255)
  passwordHash String
  role         Role     @default(PLAYER)
  avatarUrl    String?
  // Аватарка проходит модерацию: avatarUrl — то, что реально показывается всем (последнее
  // одобренное), pendingAvatarUrl — новая загрузка, ожидающая решения админа/овнера.
  pendingAvatarUrl String?
  avatarStatus     AvatarStatus? // null = нет заявки на рассмотрении
  avatarReviewedById String?
  avatarRejectedReason String? @db.VarChar(500)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Бан — глобальный запрет на вход. IP сохраняется при регистрации и последних входах,
  // чтобы можно было банить и по IP (от повторной регистрации с того же устройства).
  isBanned     Boolean   @default(false)
  bannedAt     DateTime?
  bannedReason String?   @db.VarChar(500)
  bannedById   String?
  registrationIp String? @db.VarChar(64)
  lastLoginIp    String? @db.VarChar(64)

  // Отстранение от игр — мягче полного бана: аккаунт остаётся рабочим (можно заходить на сайт,
  // писать в чат и т.д.), но запрещено участвовать в лобби/командах/матчах. suspendedUntil = null
  // означает бессрочное отстранение (до ручного снятия), иначе — дата, после которой оно снимается само.
  isSuspended       Boolean   @default(false)
  suspendedAt       DateTime?
  suspendedUntil    DateTime?
  suspendedReason   String?   @db.VarChar(500)
  suspendedById     String?

  // Привязка Discord — обязательна для участия в лобби. discordId уникален: один Discord-аккаунт
  // не может быть привязан к двум разным пользователям сайта.
  discordId       String? @unique @db.VarChar(32)
  discordUsername String? @db.VarChar(64)
  discordAvatar   String? @db.VarChar(255)
  discordLinkedAt DateTime?
  // Текущая Voice-роль, выданная боту — храним, чтобы при следующей синхронизации точно знать,
  // какую роль снимать, даже если discord_id или состояние команды изменилось между запросами.
  discordCurrentVoiceRole String? @db.VarChar(64)

  // Реферальная система — у каждого пользователя есть свой неизменный код для приглашений.
  // referredById — кто привёл этого пользователя (null для тех, кто пришёл сам, без ссылки).
  referralCode String? @unique @db.VarChar(16)
  referredById String?
  referredBy   User?   @relation("ReferralTree", fields: [referredById], references: [id], onDelete: SetNull)
  referrals    User[]  @relation("ReferralTree")

  staticId        StaticId?
  organizedMatches Match[]        @relation("OrganizerMatches")
  lobbyMemberships LobbyMember[]
  chatMessages     ChatMessage[]
  complaints       Complaint[]    @relation("ComplaintAuthor")
  reviewedComplaints Complaint[]  @relation("ComplaintReviewer")
  complaintReplies  ComplaintReply[]
  achievements     Achievement[]
  wins             Win[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  refreshTokens    RefreshToken[]
  pollVotes        PollVote[]
  amnestyConflicts AmnestyRequest[] @relation("AmnestyConflictUser")
  amnestyReviews   AmnestyRequest[] @relation("AmnestyReviewer")
  stackMembership  StackMember?
  stackJoinRequests StackJoinRequest[]
  captainOfStack   Stack?           @relation("StackCaptain")

  // Токены — внутренняя валюта платформы. Зарабатываются победами, тратятся в магазине эффектов.
  tokenBalance       Int       @default(0)
  activeUsernameEffect String? @db.VarChar(64) // ключ активного эффекта из каталога
  cosmetics          UserCosmetic[]
  tokenTransactions  TokenTransaction[]

  @@index([role])
  @@index([isBanned])
  @@index([registrationIp])
  @@index([discordId])
  @@index([referredById])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  @@index([userId])
}

model StaticId {
  id        String   @id @default(uuid())
  value     String   @unique @db.VarChar(64)
  proofUrl  String? // ссылка на скрин-пруф Static ID (загружается через yapix или аналог)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ───────────────────────── MAPS / ZONES ─────────────────────────

model GameMap {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(64)
  imageUrl  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  zones   Zone[]
  matches Match[]
}

model Zone {
  id          String   @id @default(uuid())
  mapId       String
  map         GameMap  @relation(fields: [mapId], references: [id], onDelete: Cascade)
  name        String   @db.VarChar(64)
  // adjacencyMap: список id соседних зон (граф соседства)
  adjacentIds String[] @default([])
  // координаты/полигон для отображения на карте (в %)
  coordinates Json?

  matchesSelected Match[] @relation("SelectedZones")
  matchesFinal    Match[] @relation("FinalZone")

  @@index([mapId])
}

// ───────────────────────── MATCH / LOBBY ─────────────────────────

model Match {
  id          String      @id @default(uuid())
  mapId       String
  map         GameMap     @relation(fields: [mapId], references: [id])
  organizerId String
  organizer   User        @relation("OrganizerMatches", fields: [organizerId], references: [id])
  mode        MatchMode
  status      MatchStatus @default(DRAFT)

  startTime   DateTime // UTC
  finishedAt  DateTime?

  // Окно входа в стартовую зону — открывается кнопкой "Старт" в лобби (по умолчанию 2 минуты,
  // организатор может задать своё значение через zoneEntrySeconds)
  startZoneOpenedAt DateTime?
  startZoneClosesAt DateTime?

  // Длительность окна на заход в зону (в секундах) — кастомизируется организатором,
  // применяется и к стартовой, и к финальной зоне. По умолчанию 120 секунд (2 минуты).
  zoneEntrySeconds Int @default(120)

  // Пауза матча — приостанавливает отсчёт таймера зоны. pausedAt фиксирует момент паузы,
  // remainingZoneSeconds сохраняет сколько секунд оставалось до закрытия зоны на тот момент,
  // чтобы при снятии паузы выставить новый closesAt от текущего момента, а не от старого.
  pausedAt              DateTime?
  remainingZoneSeconds  Int?

  selectedZones Zone[] @relation("SelectedZones")
  finalZoneId   String?
  finalZone     Zone?   @relation("FinalZone", fields: [finalZoneId], references: [id])
  finalZoneOpenedAt DateTime?
  finalZoneClosesAt DateTime?

  winnerTeamId String?
  winnerTeam   Team?   @relation("WinnerOfMatch", fields: [winnerTeamId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lobby Lobby?
  wins  Win[]

  @@index([status])
  @@index([startTime])
}

model Lobby {
  id        String     @id @default(uuid())
  matchId   String     @unique
  match     Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  state     LobbyState @default(DRAFT)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  teams Team[]
}

model Team {
  id          String  @id @default(uuid())
  lobbyId     String
  lobby       Lobby   @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  name        String  @db.VarChar(64)
  slot        Int // порядковый номер для отображения/Discord-ролей (назначается по порядку создания)
  isReady     Boolean @default(false)
  // Капитан — игрок, создавший команду. Только он может кикать участников из своей команды.
  createdById String?

  members      LobbyMember[]
  wonMatches   Match[]       @relation("WinnerOfMatch")
  wins         Win[]

  @@index([lobbyId])
}

model LobbyMember {
  id       String   @id @default(uuid())
  lobbyId  String
  teamId   String?
  team     Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Динамический ID — личный номер игрока на сервере в этой конкретной игровой сессии
  // (в отличие от Static ID, который закреплён за аккаунтом навсегда). Вводится при входе в лобби.
  dynamicId String? @db.VarChar(16)
  // Отмечается кнопкой "Мы умерли" самим игроком/командой — организатор видит, сколько
  // живых команд/игроков осталось, без необходимости спрашивать в чате или по войсу.
  isEliminated Boolean @default(false)
  joinedAt DateTime @default(now())

  @@unique([lobbyId, userId])
  @@index([teamId])
}

// ───────────────────────── CHAT / NOTIFICATIONS ─────────────────────────

model ChatMessage {
  id        String   @id @default(uuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  text      String   @db.VarChar(500)
  pollId    String?  // если сообщение — это карточка голосования
  // null — сообщение в общем чате; иначе — id матча, чьё лобби-чат содержит это сообщение
  lobbyMatchId String?
  // Чат конкретной команды внутри лобби — видят только участники этой команды.
  // Если задано, lobbyMatchId всё равно указывает на матч (для удобной фильтрации по матчу).
  teamId    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([lobbyMatchId])
  @@index([teamId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @db.VarChar(64)
  payload   Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

// ───────────────────────── AMNESTY (конфликт Static ID при регистрации) ─────────────────────────

model AmnestyRequest {
  id     String        @id @default(uuid())
  status AmnestyStatus @default(PENDING)

  // Данные, с которыми человек пытался зарегистрироваться — нужны, чтобы создать аккаунт,
  // если админ одобрит заявку (пароль уже хеширован на момент попытки регистрации).
  username     String @db.VarChar(32)
  email        String @db.VarChar(255)
  passwordHash String
  staticId     String @db.VarChar(64)
  proofUrl     String?
  detectedStaticId String? // что реально распознал ИИ на скрине (может отличаться от введённого)

  // Аккаунт, с которым произошёл конфликт по Static ID
  conflictUserId String?
  conflictUser   User?   @relation("AmnestyConflictUser", fields: [conflictUserId], references: [id], onDelete: SetNull)

  reviewerId String?
  reviewer   User?   @relation("AmnestyReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  adminComment String? @db.VarChar(1000)

  registrationIp String? @db.VarChar(64)
  createdAt      DateTime @default(now())
  resolvedAt     DateTime?

  @@index([status])
  @@index([staticId])
}

// ───────────────────────── COMPLAINTS ─────────────────────────

model Complaint {
  id            String          @id @default(uuid())
  authorId      String
  author        User            @relation("ComplaintAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  nick          String          @db.VarChar(64)
  staticIdValue String?         @db.VarChar(64)
  text          String          @db.VarChar(2000)
  mediaUrls     String[]        @default([]) // изображения/видео, прикреплённые автором, организатором или админом
  status        ComplaintStatus @default(NEW)
  adminComment  String?         @db.VarChar(2000) // оставлено для обратной совместимости; новые ответы — через ComplaintReply
  reviewerId    String?
  reviewer      User?           @relation("ComplaintReviewer", fields: [reviewerId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  replies ComplaintReply[]

  @@index([status])
  @@index([authorId])
}

model ComplaintReply {
  id          String    @id @default(uuid())
  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  text        String    @db.VarChar(2000)
  mediaUrls   String[]  @default([])
  createdAt   DateTime  @default(now())

  @@index([complaintId])
}

// ───────────────────────── ACHIEVEMENTS / WINS ─────────────────────────

model Achievement {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type     String   @db.VarChar(64)
  title    String   @db.VarChar(128)
  earnedAt DateTime @default(now())

  @@index([userId])
}

model Win {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([matchId])
}

// ───────────────────────── TOKENS / COSMETICS ─────────────────────────

model UserCosmetic {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cosmeticKey String   @db.VarChar(64)
  purchasedAt DateTime @default(now())

  @@unique([userId, cosmeticKey])
  @@index([userId])
}

model TokenTransaction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String   @db.VarChar(128)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ───────────────────────── STACKS (постоянные команды/кланы) ─────────────────────────

model Stack {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(64)
  tag         String   @db.VarChar(4)   // короткий тег, например [WOLF]
  tagColor    String   @default("#4f7fff") @db.VarChar(16) // HEX цвет тега
  logoUrl     String?
  description String?  @db.VarChar(500)
  captainId   String   @unique
  captain     User     @relation("StackCaptain", fields: [captainId], references: [id])
  members     StackMember[]
  joinRequests StackJoinRequest[]
  wins        StackWin[]
  createdAt   DateTime @default(now())

  @@index([name])
}

model StackMember {
  id        String   @id @default(uuid())
  stackId   String
  stack     Stack    @relation(fields: [stackId], references: [id], onDelete: Cascade)
  userId    String   @unique   // один игрок — один стак
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@index([stackId])
}

model StackJoinRequest {
  id        String   @id @default(uuid())
  stackId   String
  stack     Stack    @relation(fields: [stackId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String?  @db.VarChar(256)
  status    String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt DateTime @default(now())

  @@unique([stackId, userId])
  @@index([stackId, status])
}

model StackWin {
  id        String   @id @default(uuid())
  stackId   String
  stack     Stack    @relation(fields: [stackId], references: [id], onDelete: Cascade)
  matchId   String
  createdAt DateTime @default(now())

  @@unique([stackId, matchId])
  @@index([stackId])
}

// ───────────────────────── NEWS / MEDIA ─────────────────────────

model News {
  id        String   @id @default(uuid())
  slug      String   @unique @db.VarChar(128)
  title     String   @db.VarChar(255)
  excerpt   String?  @db.VarChar(500)
  body      String
  coverUrl  String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Media {
  id        String   @id @default(uuid())
  title     String   @db.VarChar(255)
  type      String   @db.VarChar(32) // "youtube" | "twitch" | "embed" | "link"
  url       String
  thumbUrl  String?
  createdAt DateTime @default(now())
}

// ───────────────────────── AUDIT LOG ─────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String   @db.VarChar(128)
  entityType String   @db.VarChar(64)
  entityId   String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ───────────────────────── POLLS (голосование за карту/режим) ─────────────────────────

model Poll {
  id        String       @id @default(uuid())
  title     String       @db.VarChar(255)
  createdById String
  isClosed  Boolean      @default(false)
  createdAt DateTime     @default(now())
  closedAt  DateTime?

  options PollOption[]

  @@index([createdAt])
}

model PollOption {
  id     String @id @default(uuid())
  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  label  String @db.VarChar(128) // например "Redwood · 4x4"

  votes PollVote[]

  @@index([pollId])
}

model PollVote {
  id       String     @id @default(uuid())
  optionId String
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([optionId, userId])
  @@index([userId])
}
